# PropTech News Monitoring — environment template
# Copy to .env (gitignored) and fill in real values.
# See docs/cowork-onboarding.md § B.3 for the full guide.

# --- LLM (optional; Claude Cowork runs mode prompts itself) ---
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini

# --- Telegram delivery (tools/telegram_send.py) ---
# Required for any delivery_profile (telegram_digest, telegram_weekly_digest, telegram_alert).
# Create a bot via @BotFather, add it to the target chat/forum, then:
#   chat_id: @userinfobot in the chat, or getUpdates API
#   message_thread_id: leave empty if the chat is not a forum
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=

# --- Fetch (tools/rss_fetch.py and any outbound HTTP) ---
# Used as the User-Agent header. Replace the email with a real contact
# so site owners can reach you if the crawler misbehaves.
HTTP_USER_AGENT=PropTechNewsMonitor/1.0 (+team@example.com)
